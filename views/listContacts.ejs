<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CSCE 20303 | List Contacts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  </head>
  <body>
 
    <nav class="navbar navbar-light bg-light" style="margin-bottom: 20px; padding: 10px;">
    <a class="navbar-brand" href="/">
        CSCE 20303 Web Systems
    </a>
    </nav>
    <div class="container">
        <div class="col">
        <a class="btn btn-primary" href="/add" role="button">Add Contact</a>
            <table class="table table-bordered table-striped">
                <thead><tr><th>Contact ID</th><th>Contact Name</th><th>Email</th></tr></thead>
                <tbody>
                    <% contacts.forEach(contact => { %>
                    <tr>
                        <td><%= contact.contactID %></td>
                        <td><%= contact.username %></td>
                        <td><%= contact.email %></td>
                    </tr>
                    <% }) %>
                </tbody>        
            </table>       
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>